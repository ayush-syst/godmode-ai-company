# =============================================================================
# Godmode AI Company — .env.example
# -----------------------------------------------------------------------------
# Copy to the repo root as `.env` and fill in real values:
#     cp bootstrap/.env.example .env
#
# ⚠️  NEVER COMMIT `.env`. It is git-ignored (see .gitignore). This *.example
#     file contains ONLY placeholders and is safe to commit. If you ever paste a
#     real key here by mistake, rotate it immediately (see company-os/09-security.md).
#
# Most of the swarm runs on FREE tiers — you do NOT need every key to start.
# Minimum to do something useful:  ANTHROPIC_API_KEY + one free key (GEMINI/GROQ).
# =============================================================================

# ── CRITICAL PATH — Claude (the $20 sub powers Layer-1 gates) ────────────────
# The one paid anchor. Used by gstack + claude-gate alias in litellm-config.yaml.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FREE TIERS — the swarm engine (get the ones you'll use) ──────────────────
# Google AI Studio (Gemini 2.5 Flash/Pro) — ~1,500 req/day, 1M ctx, no card.
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Groq (Llama 3.3 70B) — 300+ tok/s, ~1,000 req/day.  https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Cerebras — highest free throughput.  https://cloud.cerebras.ai
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxx

# ── CHEAP PAYG — bulk coding/reasoning workers ──────────────────────────────
# DeepSeek (V3/R1) — 5M free tokens at signup, then very cheap.  https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# OpenRouter — aggregator for the long tail (Qwen, free models, auto-routing).
#   $10 one-time -> 1,000 req/day.  https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# Optional direct providers (otherwise reached via OpenRouter):
# Qwen / Alibaba DashScope — 1M free tokens (90-day).  https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=
# SambaNova — free via email.  https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# Optional: OpenAI key ONLY if you use gstack /codex (OpenAI cross-review).
OPENAI_API_KEY=

# ── LOCAL MODELS — Ollama (unlimited, your hardware; embeddings + safety net) ─
# Install: https://ollama.com  then `ollama pull llama3.2 && ollama pull nomic-embed-text`
OLLAMA_API_BASE=http://localhost:11434

# ── TOKEN OPTIMIZER — LiteLLM proxy + cache + observability ──────────────────
# Master key clients use to auth to the proxy. Generate any strong random string.
LITELLM_MASTER_KEY=sk-litellm-CHANGE-ME-to-a-long-random-string
# Optional Postgres for per-key budgets/usage (leave blank to run in-memory):
DATABASE_URL=

# Redis — semantic cache backing store (run: docker run -d -p 6379:6379 redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Langfuse — cost/latency observability (self-host or cloud).  https://langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=http://localhost:3000

# ── COMPANY BRAIN / DATA — Supabase (DB, auth, storage) ─────────────────────
#   https://supabase.com  (free tier to start)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side ONLY; never ship to a client

# ── PAYMENTS — Razorpay (India-first) + Stripe (international, optional) ─────
# Razorpay: UPI/cards/netbanking for India.  https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Stripe (only if selling outside India):
STRIPE_SECRET_KEY=

# ── INFRA / OBSERVABILITY (optional until you deploy) ───────────────────────
CLOUDFLARE_API_TOKEN=          # CDN/WAF/Tunnels.  https://dash.cloudflare.com
SENTRY_DSN=                    # error tracking.  https://sentry.io

# ── AUTOMATION — n8n (self-hosted glue for marketing/sales/support) ─────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong-password

# ── SALES enrichment (optional free tiers) ──────────────────────────────────
APOLLO_API_KEY=               # 50 free email enrichments/mo.  https://apollo.io
HUNTER_API_KEY=               # 25 free email finds/mo.  https://hunter.io

# ── RESEARCH — Firecrawl (clean web->markdown for research crews) ───────────
FIRECRAWL_API_KEY=            # https://firecrawl.dev  (free tier available)
